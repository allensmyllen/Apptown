{
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|next" }],
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["client/src/**/*.{js,jsx}"],
      "env": { "browser": true },
      "plugins": ["react"],
      "rules": {
        "react/jsx-uses-react": "error",
        "react/jsx-uses-vars": "error"
      }
    },
    {
      "files": ["server/**/*.js"],
      "env": { "node": true, "browser": false }
    }
  ]
}
